{
  "name": "nia-medtourism",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:push": "prisma migrate dev --schema=packages/shared/prisma/schema.prisma",
    "db:seed": "prisma db seed --schema=packages/shared/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=packages/shared/prisma/schema.prisma"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild", "bufferutil"]
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
