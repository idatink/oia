# Database (Vercel Postgres / Neon)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# NextAuth
AUTH_SECRET=                        # openssl rand -base64 32
AUTH_URL=http://localhost:3001      # production: https://your-domain.com

# Pusher (real-time coordinator alerts)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# WhatsApp messaging provider (swap implementation in packages/whatsapp/src/providers/)
# Twilio example:
WA_ACCOUNT_SID=
WA_AUTH_TOKEN=
WA_FROM_NUMBER=whatsapp:+14155238886

# LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
NIA_MODEL=gpt-4o-mini

# Redis (queues, rate limiting)
REDIS_URL=redis://localhost:6379

# Storage (S3-compatible — documents and images)
S3_BUCKET=nia-documents
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
